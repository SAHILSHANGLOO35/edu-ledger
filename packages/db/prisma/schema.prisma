generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String      @id @default(uuid())
  email     String      @unique
  phone     String      @unique
  password  String
  purchases Purchases[]
}

model Course {
  id               String      @id @default(uuid())
  title            String
  slug             String      @unique
  calendarNotionId String?
  purchases        Purchases[]
}

model Purchases {
  id       String @id @default(uuid())
  courseId String
  userId   String
  course   Course @relation(fields: [courseId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
}
